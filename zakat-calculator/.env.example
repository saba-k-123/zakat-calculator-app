# Zakat Guide - Environment Variables
# Copy this file to .env.local and fill in values

# Google Analytics (optional - tracking ID)
NEXT_PUBLIC_GA_ID=

# Stock price APIs (optional - app falls back to Yahoo Finance scraping)
ALPHA_VANTAGE_API_KEY=
IEX_CLOUD_API_KEY=

# Exchange rate API (optional - app falls back to Frankfurter API)
EXCHANGE_RATE_API_KEY=
